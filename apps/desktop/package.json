{
  "name": "clawt-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "clawT desktop GUI for Hermes Agent with a bundled runtime",
  "author": {
    "name": "Thomas",
    "email": "thomas@users.noreply.github.com"
  },
  "homepage": "https://github.com/Thomas-ry/hermes-clawT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "icons:build": "python3 ../../scripts/generate-icons.py",
    "package": "pnpm icons:build && node ../../scripts/require-runtime.mjs && pnpm build && electron-builder",
    "package:mac": "pnpm icons:build && node ../../scripts/require-runtime.mjs && pnpm build && electron-builder --mac",
    "package:win": "pnpm icons:build && node ../../scripts/require-runtime.mjs && pnpm build && electron-builder --win",
    "package:linux": "pnpm icons:build && node ../../scripts/require-runtime.mjs && pnpm build && electron-builder --linux",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.8.0",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  },
  "main": "dist-electron/main.js"
}
