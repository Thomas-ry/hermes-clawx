{
  "name": "hermes-clawx",
  "version": "0.1.0",
  "description": "Desktop visual client for Hermes Agent, inspired by the ClawX experience",
  "author": {
    "name": "Thomas",
    "email": "thomas@users.noreply.github.com"
  },
  "homepage": "https://github.com/Thomas-ry/hermes-clawx",
  "repository": {
    "type": "git",
    "url": "https://github.com/Thomas-ry/hermes-clawx.git"
  },
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "icons:build": "python3 ./scripts/generate-icons.py",
    "runtime:build": "node ./scripts/build-hermes-runtime.mjs",
    "setup": "node ./scripts/bootstrap.mjs",
    "doctor": "node ./scripts/env-doctor.mjs",
    "dev": "pnpm -C apps/desktop dev",
    "build": "pnpm -C apps/desktop build",
    "lint": "pnpm -C apps/desktop lint",
    "test": "pnpm -C apps/desktop test",
    "package": "pnpm -C apps/desktop package",
    "package:mac": "pnpm -C apps/desktop package:mac",
    "package:win": "pnpm -C apps/desktop package:win",
    "package:linux": "pnpm -C apps/desktop package:linux"
  }
}
